# ================================================
# OpenChildRisk OS — Root Environment Variables
# Copy to .env and fill in values before deploying
# ================================================

# --- PostgreSQL ---
DB_DATABASE=openchildrisk
DB_USERNAME=ocr_user
DB_PASSWORD=change_me_strong_password

# --- MinIO (S3-compatible object storage) ---
MINIO_USER=ocr_minio
MINIO_PASSWORD=change_me_minio_password

# --- Laravel App ---
APP_KEY=                        # Run: docker compose exec app php artisan key:generate --show
APP_ENV=production
APP_DEBUG=false
APP_URL=http://your-ec2-ip      # e.g. http://54.123.45.67 or https://yourdomain.com

# --- Risk Engine ---
RISK_ENGINE_URL=http://risk-engine:8001

# --- CHIRPS Rainfall API ---
CHIRPS_API_ENABLED=false        # Set true when ready to pull live rainfall data

# --- Redis ---
REDIS_PASSWORD=                 # Leave blank for no auth (internal Docker network only)
